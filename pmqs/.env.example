# PMQs environment — copy to .env and fill in. NEVER commit .env (it is gitignored).
#
# How keys are stored in this project:
#   - The secret VALUE lives in an env var (here, or the process/deployment env).
#   - Settings in the DB store only the NAME of that env var (api_key_ref), never the
#     raw key. See pmqs/pmqs/settings.py and pmqs/pmqs/llm.py.

# --- LLM provider (default: OpenRouter, an OpenAI-compatible gateway) ---
# Referenced by settings._LLM_DEFAULTS["api_key_ref"]. Get one at openrouter.ai/keys.
OPENROUTER_API_KEY=

# Optional: only needed if you switch the LLM default back to native Anthropic
# (provider "anthropic", empty base_url) instead of OpenRouter.
# ANTHROPIC_API_KEY=

# --- News / Brave Search (Phase 4) ---
# Referenced by settings._NEWS_DEFAULTS["api_key_ref"]. Leave blank to disable news.
BRAVE_API_KEY=

# --- LLM resolution mode (optional) ---
# 'hermes' (default) inherits a local Hermes install's credentials; 'api' reads a key
# from the env; 'off' forces the deterministic/heuristic fallback (used by tests).
# When Settings are configured (the default path), they take precedence unless mode=off.
# PMQS_LLM_MODE=hermes

# --- Local overrides (optional; see pmqs/pmqs/config.py for the full list) ---
# PMQS_DB_PATH=
# PMQS_AGENTOS_REPO=open-agentos/agentos-pmqs
